generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  full_name   String
  email       String    @unique
  phone       String?
  password    String
  role        String?   @default("student")
  is_verified Boolean?  @default(false)
  created_at  DateTime? @default(now()) @db.Timestamp(6)

  residences  Residence[]
  bookings    Booking[]

  @@map("users")
}

model Residence {
  id              String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  owner_id        String?   @db.Uuid
  title           String
  description     String?
  city            String
  address         String?
  price_per_month Decimal   @db.Decimal
  is_available    Boolean?  @default(true)
  category        String?
  created_at      DateTime? @default(now()) @db.Timestamp(6)

  owner           User?             @relation(fields: [owner_id], references: [id], onDelete: Cascade)
  images          ResidenceImage[]
  bookings        Booking[]

  @@map("residences")
}

model ResidenceImage {
  id           String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  residence_id String?   @db.Uuid
  image_url    String
  is_main      Boolean?  @default(false)

  residence    Residence? @relation(fields: [residence_id], references: [id], onDelete: Cascade)

  @@map("residence_images")
}

model Booking {
  id           String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  residence_id String?   @db.Uuid
  student_id   String?   @db.Uuid
  status       String?   @default("pending")
  message      String?
  created_at   DateTime? @default(now()) @db.Timestamp(6)

  residence    Residence? @relation(fields: [residence_id], references: [id], onDelete: Cascade)
  student      User?      @relation(fields: [student_id], references: [id], onDelete: Cascade)

  @@map("bookings")
}
